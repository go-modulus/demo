# Environment variables for the application
# Place here all your environment variables that you want to use in your application with default values

APP_ENV=local

LOGGER_APP=app
# Use one of "debug", "info", "warn", "error". It sets the minimum level of the fx events that should be logged
LOGGER_FX_EVENT_LEVEL=warn
# Use one of "debug", "info", "warn", "error". It sets the minimum level of the log messages that should be logged
LOGGER_LEVEL=debug
# Use either "console" or "json" value
LOGGER_TYPE=console


# Use this variable to set the DSN for the PGX connection. It overwrites the other PG_* variables. Example: PGX_DSN=postgres://postgres:foobar@localhost:5432/test?sslmode=disable
PGX_DSN=
PG_DB_NAME=test
PG_HOST=localhost
PG_PASSWORD=foobar
PG_PORT=5432
PG_SSL_MODE=disable
PG_USER=postgres


# Comma-separated list of additional allowed headers for CORS requests
CORS_ADDITIONAL_ALLOWED_HEADERS=[]
# Regular expression pattern for allowed origins or * for all origins
CORS_HOST=^https?://(localhost|127.0.0.1)(:[0-9]+)?$
CORS_MAX_AGE=3600
HTTP_HOST=localhost:8001
# Log level for the system errors: dont_log, error, warn, info, debug
HTTP_SYSTEM_ERROR_LOG_LEVEL=error
# Log level for the user errors: dont_log, error, warn, info, debug
HTTP_USER_ERROR_LOG_LEVEL=dont_log
ROUTER_REQUEST_SIZE_LIMIT=5MB
ROUTER_TTL=15s


GQL_API_URL=/graphql
GQL_COMPLEXITY_LIMIT=200
GQL_INTROSPECTION_ENABLED=true
GQL_PLAYGROUND_ENABLED=true
GQL_PLAYGROUND_URL=/playground
GQL_RETURN_CAUSE=false
GQL_TRACING_ENABLED=false


AUTH_ACCESS_TOKEN_TTL=1h0m0s
AUTH_REFRESH_TOKEN_TTL=720h0m0s
AUTH_RESET_PASSWORD_LIFE=1h0m0s
AUTH_RESET_PASSWORD_RESEND_COOLDOWN=5m0s


FRONTEND_HOST=


RECAPTCHA_ENABLED=false
RECAPTCHA_V2_SECRET=
RECAPTCHA_V3_SECRET=
RECAPTCHA_V3_THRESHOLD=0.5
